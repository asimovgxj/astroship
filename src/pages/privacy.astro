---
import Layout from "../layouts/Layout.astro";
import Container from "../components/container.astro";
---
<Layout title="Privacy Policy">
  <Container>
    <div class="mx-auto max-w-3xl mt-14 mb-20">
      <h1 class="text-4xl font-bold text-slate-800">Privacy Policy</h1>
      <div class="mt-6 text-slate-600 leading-relaxed space-y-4">
        <p>At AutoChina Intelligence, we prioritize your privacy. We only collect your email address via Buttondown for the sole purpose of delivering our weekly reports.</p>
        <p><strong>Data Collection:</strong> We do not use third-party tracking cookies. Your email is stored securely and will never be sold to third parties.</p>
        <p><strong>Opt-out:</strong> You can unsubscribe at any time via the link in our emails.</p>
      </div>
    </div>
  </Container>
</Layout>
