---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Container from "../components/container.astro";
import Sectionhead from "../components/sectionhead.astro";

// 1. Fetch all articles belonging to the Market category
const marketEntries = await getCollection("blog", ({ data }) => {
  return data.category === "Market";
});

// 2. Sort by date in descending order
marketEntries.sort((a, b) => 
  b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

// 3. Universal image resolver
// Handles both object and string ID formats in Markdown
const resolveImg = (imgData) => {
  if (!imgData) return "";
  
  // A. If object format {src: "...", alt: "..."}, extract the src string
  let rawUrl = typeof imgData === 'object' ? imgData.src : imgData;
  
  // B. If it's already a full HTTP link, return it directly
  if (rawUrl.startsWith("http")) return rawUrl;
  
  // C. If it's a pure ID (e.g., photo-xxx), perform hex concatenation
  // \x2f is a slash, preventing truncation by display engines
  const p1 = "https://images.unsplash.com" + "\x2f";
  return `${p1}${rawUrl}?auto=format&fit=crop&w=800&q=80`;
};
---

<Layout title="Market Intelligence | AutoChina.org">
  <Container>
    <Sectionhead>
      <Fragment slot="title">Market Intelligence</Fragment>
      <Fragment slot="desc">
        Strategic insights and real-time analysis on the Chinese BEV competitive landscape.
      </Fragment>
    </Sectionhead>
    <main class="mt-16">
      <ul class="grid gap-16 max-w-4xl mx-auto">
        {marketEntries.map((entry) => (
          <li>
            <a href={`/blog/${entry.slug}`}>
              <div class="grid md:grid-cols-2 gap-5 md:gap-10 items-center group">
                <div class="overflow-hidden rounded-md bg-slate-100 aspect-video">
                  <!-- Use the universal resolver to ensure images display correctly -->
                  <img
                    src={resolveImg(entry.data.image)}
                    alt={entry.data.title}
                    width="800"
                    height="600"
                    loading="lazy"
                    decoding="async"
                    class="w-full h-full object-cover transition duration-300 group-hover:scale-105"
                  />
                </div>
                <div>
                  <span class="text-emerald-600 uppercase text-xs font-bold tracking-wider">
                    {entry.data.category}
                  </span>
                  <h2 class="text-2xl font-bold mt-2 text-slate-800 group-hover:text-emerald-700 transition">
                    {entry.data.title}
                  </h2>
                  <p class="text-slate-500 mt-2 line-clamp-3 italic">
                    {entry.data.snippet}
                  </p>
                </div>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </main>
  </Container>
</Layout>
