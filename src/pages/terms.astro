---
import Layout from "../layouts/Layout.astro";
import Container from "../components/container.astro";
---
<Layout title="Terms of Service">
  <Container>
    <div class="mx-auto max-w-3xl mt-14 mb-20">
      <h1 class="text-4xl font-bold text-slate-800">Terms of Service</h1>
      <div class="mt-6 text-slate-600 leading-relaxed space-y-4">
        <p>All content provided on AutoChina.org is for informational purposes only. We do not provide financial or legal advice.</p>
        <p><strong>Intellectual Property:</strong> Our unique data visualizations (SVGs) and analysis remain the property of AutoChina Intelligence. Quotation with attribution is permitted.</p>
        <p><strong>Accuracy:</strong> While we strive for precision in our tax and margin analysis, market conditions in China and Russia shift rapidly. We are not liable for business decisions made based on this site.</p>
      </div>
    </div>
  </Container>
</Layout>
