---
// src/components/cta.astro
// Maintain original visual proportions, upgrade internal button to "input + subscribe button" horizontal layout
---

<div
  class="bg-emerald-900 p-8 md:px-20 md:py-20 mt-20 mx-auto max-w-5xl rounded-2xl flex flex-col items-center text-center shadow-xl border border-white/5">
  
  <!-- 1. Restore original title -->
  <h2 class="text-white text-4xl md:text-6xl tracking-tight font-bold">
    Stay Ahead of China's Auto Market.
  </h2>
  
  <!-- 2. Restore original description copy -->
  <p class="text-emerald-100/70 mt-4 text-lg md:text-xl max-w-2xl text-center">
    Subscribe to our intelligence reports for exclusive data, policy analysis, and strategic trends in the Chinese automotive industry.
  </p>

  <!-- 3. Horizontal subscription form: Input (left) + Button (right) -->
  <form
    action="https://buttondown.email/api/emails/embed-subscribe/autochina"
    method="post"
    target="popupwindow"
    onsubmit="window.open('https://buttondown.email', 'popupwindow')"
    class="flex flex-col md:flex-row w-full max-w-md mt-10 gap-3">
    
    <!-- Input: semi-transparent white, distinct from deep green background -->
    <input
      type="email"
      name="email"
      placeholder="Enter your email..."
      required
      class="flex-1 px-5 py-3 rounded-md bg-white/10 border border-white/20 text-white placeholder:text-emerald-100/40 focus:outline-none focus:ring-2 focus:ring-white/50 transition shadow-inner"
    />
    
    <input type="hidden" value="1" name="embed" />
    
    <!-- Subscribe button: maintain original "white background green text" visual focus -->
    <button
      type="submit"
      class="bg-white text-emerald-900 hover:bg-emerald-50 px-8 py-3 rounded-md font-bold transition shadow-lg whitespace-nowrap">
      Subscribe for Free
    </button>
  </form>

  <p class="text-emerald-200/30 mt-4 text-[10px] uppercase tracking-[0.2em] font-medium">
    Independent Intelligence • 
  </p>
</div>
