---
import Container from "@/components/container.astro";
import Link from "@/components/ui/link.astro";
import Dropdown from "./dropdown.astro";
import { Astronav, MenuItems, MenuIcon } from "astro-navbar";

// Redefined industry menu for AutoChina.org
const menuitems = [
  { title: "Market", path: "/market" },
  { title: "Policy", path: "/blog" }, // Later filtered in market.astro to show Policy
  { title: "Supply Chain", path: "/blog" },
  {
    title: "Brands",
    path: "#",
    children: [
      { title: "TESLA", path: "/blog" }, 
{ title: "BYD", path: "/blog" }, // BYD as an independent tag
      { title: "Brand Tracker", path: "/blog" }, // Other brands collection
    ],
  },
  { title: "About", path: "/about" },
];

---

<Container>
  <header class="flex flex-col lg:flex-row justify-between items-center my-5">
    <Astronav>
      <div class="flex w-full lg:w-auto items-center justify-between">
        <!-- Logo changed to AutoChina with emerald green tech-style color -->
        <a href="/" class="text-xl tracking-tighter"
          ><span class="font-bold text-slate-900">Auto</span><span
            class="text-emerald-600 font-semibold">China</span
          >
        </a>
        <div class="block lg:hidden">
          <MenuIcon class="w-4 h-4 text-gray-800" />
        </div>
      </div>
      <MenuItems class="hidden w-full lg:w-auto mt-2 lg:flex lg:mt-0">
        <ul class="flex flex-col lg:flex-row lg:gap-3">
          {
            menuitems.map((item, index) => (
              <>
                {item.children && (
                  <Dropdown
                    title={item.title}
                    children={item.children}
                    lastItem={index === menuitems.length - 1}
                  />
                )}

                {!item.children && (
                  <li>
                    <a
                      href={item.path}
                      class="flex lg:px-3 py-2 items-center text-gray-600 hover:text-emerald-700 font-medium transition duration-200">
                      <span> {item.title}</span>
                    </a>
                  </li>
                )}
              </>
            ))
          }
        </ul>
      </MenuItems>
    </Astronav>
    <div>
  <div class="hidden lg:flex items-center gap-4">
    <!-- Commercialization: change navigation path to subscription anchor at homepage bottom -->
    <Link 
      href="/#subscribe-section" 
      size="md" 
      class="bg-emerald-600 hover:bg-emerald-700 text-white px-4 py-2 rounded-md transition duration-200 border-none shadow-sm font-medium">
      Subscribe
    </Link>
  </div>
</div>
  </header>
</Container>
